<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

  <targets>
    <target xsi:type="File" name="logfile"
            fileName="c:/temp/zchecklist.log"
            layout="${longdate} | ${pad:padding=-5:${uppercase:${level}}} | ${logger:shortName=true} | ${message}${onexception:inner=${newline}    EXCEPTION: ${exception:format=tostring}}"
            archiveEvery="Day"
            maxArchiveFiles="14"
            keepFileOpen="false" />

    <target xsi:type="Console" name="logconsole"
            layout="${longdate} | ${pad:padding=-5:${uppercase:${level}}} | ${logger:shortName=true} | ${message}${onexception:inner= | ${exception:format=message}}" />
  </targets>

  <rules>
    <!-- Suppress noisy Microsoft/System framework logs below Warn -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- App errors/warnings go to file -->
    <logger name="*" minlevel="Warn" writeTo="logfile" />

    <!-- Info and above go to console (matches existing dev experience) -->
    <logger name="*" minlevel="Info" writeTo="logconsole" />
  </rules>
</nlog>
